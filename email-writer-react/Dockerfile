# Build stage
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Production stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
# Copy standard nginx config if needed, but default is fine for single page apps without deep routing.
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
